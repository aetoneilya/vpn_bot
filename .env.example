# Telegram bot token from BotFather
TELOXIDE_TOKEN=123456:ABCDEF

# 3X-UI panel connection
XUI_BASE_URL=http://your-panel-host:2053
# If your panel opens as /<secret>/panel/... then include only /<secret> here
# Example: https://host:2053/204e52bf575587135a3705e2cdcf9864
XUI_USERNAME=admin
XUI_PASSWORD=change_me
XUI_INBOUND_ID=1

# Optional behavior
# Comma-separated Telegram user IDs allowed to run /create.
# If unset, any Telegram user who can message the bot is allowed.
ALLOW_USER_IDS=
# Comma-separated Telegram user IDs who can approve/deny requests (required).
APPROVER_USER_IDS=123456789

# Client limits
XUI_TOTAL_GB=0

# Optional endpoint overrides for different panel versions
XUI_LOGIN_PATH=/login
XUI_ADD_CLIENT_PATH=/panel/api/inbounds/addClient
XUI_DELETE_CLIENT_PATH=/panel/api/inbounds/{id}/delClient/{clientId}
XUI_GET_INBOUND_PATH=/panel/api/inbounds/get/{id}
XUI_LIST_INBOUNDS_PATH=/panel/api/inbounds/list

# SQLite database path for pending approval requests
SQLITE_PATH=vpn_bot.sqlite3
